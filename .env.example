OPENAI_API_KEY=sk-proj-...

# Telegram Bot API credentials
# 1. Create a bot: message @BotFather on Telegram → /newbot → copy the token
# 2. Start a chat with your bot, then get your chat ID:
#    curl "https://api.telegram.org/bot<TOKEN>/getUpdates"
#    Look for "id" inside "chat" in the response
TELEGRAM_BOT_TOKEN=123456789:ABC-your-token-here
TELEGRAM_CHAT_ID=123456789
